# Las variables para la base de datos y la conexion FTP se reciben del .env del proyecto padre al ejecutar el docker compose

# Esquema PostgreSQL sobre el que corre Auth-Service.
DB_SCHEMA=auth

# Bandera para habilitar o deshabilitar autenticacion LDAP.
LDAP_AUTHENTICATION=true
# Host del servidor LDAP.
LDAP_HOST=localhost
# Puerto del servidor LDAP.
LDAP_PORT=389
# Prefijo del administrador LDAP usado para construir el bindDN.
LDAP_ADMIN_PREFIX=cn
# Usuario administrador LDAP usado en el bindDN.
LDAP_ADMIN_USERNAME=root
# Contraseña del administrador LDAP usada como bindCredentials.
LDAP_ADMIN_PASSWORD=password
# Prefijo pensado para cuentas LDAP de usuario final.
LDAP_ACCOUNT_PREFIX=uid
# Sufijo o rama LDAP de las cuentas de usuario.
LDAP_ACCOUNT_SUFFIX="o=users"
# Base DN usada para bind y busqueda en LDAP.
LDAP_BASEDN="dc=example,dc=com"

# Secreto con el que se crean y verifican los JWT.
JWT_SECRET='your_jwt_secret'
# Llave usada para validar integraciones internas por API key.
API_KEY=''

# Identificador de dispositivo o usuario habilitado para pruebas.
USER_TEST_DEVICE=99999
# Habilita el acceso directo del dispositivo de pruebas.
USER_TEST_ACCESS=false
