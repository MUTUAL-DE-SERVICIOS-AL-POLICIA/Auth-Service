# ============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - Auth-Service
# ============================================================================

# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Actualiza los valores según tu entorno



# DATABASE CONFIGURATION - POSTGRESQL

# DB_HOST - DIRECCION DEL SERVIDOR POSTGRES
# Especifica dónde está ubicada la base de datos PostgreSQL.
DB_HOST=192.168.X.XXX

# DB_PORT - PUERTO DONDE POSTGRESQL ESCUCHA
DB_PORT=5432

# DB_USERNAME - USUARIO DE POSTGRESQL
DB_USERNAME=postgres

# DB_PASSWORD - CONSTRASEÑA DEL USUARIO DE POSTGRESQL
DB_PASSWORD=999999

# DB_DATABASE - NOMBRE DE LA BASE DE DATOS
DB_DATABASE=platform

# DB_SCHEMA - Schema de PostgreSQL
#  Define el "namespacio" donde están las tablas dentro de la base de datos.
DB_SCHEMA=public

# DB_SYNCHRONIZE - Sincronización automática de esquema
#   Si es TRUE: TypeORM sincroniza automáticamente la estructura de la base de datos
#               con las entidades de código (crea/modifica tablas automáticamente)
#   Si es FALSE: NO sincroniza automáticamente. Necesita crear migraciones manuales para cambios
DB_SYNCHRONIZE=true



# MESSAGE BROKER - NATS
# NATS es un bus de mensajes que permite comunicación asincrónica entre microservicios.

NATS_SERVERS="nats://localhost:4222"



# LDAP CONFIGURATION - Validación de usuarios contra directorio LDAP

# LDAP_AUTHENTICATION - Habilitar validación por LDAP
# TRUE: valida usuarios en el servidor LDAP
# FALSE: omite validación LDAP (autenticación local)
LDAP_AUTHENTICATION=true

# LDAP_HOST - Dirección del servidor LDAP
LDAP_HOST=192.168.X.XXX

# LDAP_PORT - Puerto donde LDAP escucha
LDAP_PORT=389

# LDAP_ADMIN_PREFIX - Atributo identificador del administrador
# Ejemplo: 
#   - cn (Common Name) = Nombre común - Usar en: Active Directory, OpenLDAP
#   - uid (User ID) = ID único - Usar en: OpenLDAP tradicional (para linux)
LDAP_ADMIN_PREFIX=uid

# LDAP_ADMIN_USERNAME - DN completo del usuario administrador LDAP
# Ejemplo: cn=admin,dc=example,dc=com
LDAP_ADMIN_USERNAME=admin

# LDAP_ADMIN_PASSWORD - Contraseña del usuario administrador LDAP
LDAP_ADMIN_PASSWORD=password

# LDAP_ACCOUNT_PREFIX - Atributo para identificar cuentas de usuario normales
# Ejemplo: 
#   - uid = ID único (OpenLDAP)
#   - cn = Nombre común (OpenLDAP alternativo)
LDAP_ACCOUNT_PREFIX=uid

# LDAP_ACCOUNT_SUFFIX - Ruta donde están almacenados los usuarios en el servidor LDAP
# Este valor lo define el administrador del servidor LDAP de tu organización
LDAP_ACCOUNT_SUFFIX="o=users"

# LDAP_BASEDN - Base DN (raíz del directorio LDAP)
# Raíz del directorio LDAP desde donde se realizan las búsquedas
LDAP_BASEDN="dc=example,dc=com"


# JWT CONFIGURATION - Autenticación con tokens

# JWT_SECRET - Clave secreta para generar y validar tokens JWT
JWT_SECRET=your_jwt_secret_here


# API SECURITY

# API_KEY - Clave de autenticación para servicios internos
# Usada por otros microservicios para llamar a este servicio
API_KEY=


# ENVIRONMENT CONFIGURATION

# ENVIRONMENT - Ambiente de ejecución
# Valores: dev (desarrollo), prod (producción)
# Afecta logs, validaciones y comportamiento de la aplicación
ENVIRONMENT=dev